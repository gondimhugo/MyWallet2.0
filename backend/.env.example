# Copie este arquivo para `.env` e preencha os valores.
#
# DATABASE_URL aceita qualquer um dos formatos abaixo — `app/core/config.py`
# normaliza o scheme (`postgres://` / `postgresql://` -> `postgresql+psycopg://`)
# e habilita `sslmode=require` automaticamente quando detecta hostnames
# externos do Render (*.render.com).

# ------- Render Postgres (INTERNO, usado quando o backend roda dentro do Render)
# DATABASE_URL=postgresql://admin:h2P8EMKMjjFbzfD93dm2o5pvUCKkirJX@dpg-d7f264jbc2fs738gbiag-a/mywallet_os4m

# ------- Render Postgres (EXTERNO, para rodar local contra o banco Render)
# Substitua <region> pela região do seu banco (ex: oregon, virginia, frankfurt, singapore, ohio).
# DATABASE_URL=postgresql://admin:h2P8EMKMjjFbzfD93dm2o5pvUCKkirJX@dpg-d7f264jbc2fs738gbiag-a.<region>-postgres.render.com/mywallet_os4m

# ------- Docker compose / Postgres local
# DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/mywallet

# Chave para assinatura de JWT (use algo aleatório e longo em produção).
SECRET_KEY=change-me

# Origens autorizadas no CORS (separadas por vírgula).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
